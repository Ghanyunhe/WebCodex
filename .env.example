PORT=8787
HOST=0.0.0.0
CODEX_WEB_TOKEN=change-me
CODEX_WEB_DEFAULT_CWD=/srv/codex/workspaces/default
CODEX_WEB_DEFAULT_MODEL=gpt-5.4
CODEX_WEB_DEFAULT_REASONING_EFFORT=medium
CODEX_WEB_MODEL_OPTIONS=gpt-5.5,gpt-5.4,gpt-5.4-mini
CODEX_WEB_TERMINAL_URL=
# Leave blank in most Linux installs so the server uses `codex app-server`
CODEX_WEB_CODEX_BIN=
# Optional explicit launcher, for example:
# CODEX_WEB_APP_SERVER_COMMAND=codex app-server
CODEX_WEB_APP_SERVER_COMMAND=
# Optional custom Codex home
CODEX_HOME=
